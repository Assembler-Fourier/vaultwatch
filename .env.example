# Copy to .env for `docker compose up`. Never commit the real .env.

POSTGRES_PASSWORD=vaultwatch-dev-only
JWT_SECRET=dev-only-change-me

# Optional: leave blank to run the whole stack in deterministic replay mode
# (zero API cost). Set it to switch agents-python to live Claude calls.
ANTHROPIC_API_KEY=

MODE=auto
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-5
